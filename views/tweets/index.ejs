<!DOCTYPE html>
<html lang="en" dir="ltr">
  <head>
    <meta charset="utf-8">
    <title></title>
  </head>

  <body>
  <h2 id='title'>Peep Timeline</h2>
    
  <div id='send-tweet'>
      <% if (currentUser) {%>
      <form action='/tweet', method='post'>
         <input id='tweet-text' type='text' name='tweet' placeholder='Type your peep here!'>
         <input type='submit' value='Save' id='save'>
      </form>
      <%}%>
  </div>

  <div id='feed'>
      <% tweets.forEach( (tweet, tweetIndex) => { %>
      <div id='tweet-<%=tweetIndex%>-div'>
          <span id='tweet-<%=tweetIndex%>'><%= tweet.text %> </span>
          <span id='tweet-<%=tweetIndex%>-timestamp'><%= tweet.date %></span>
          <span id='tweet-<%=tweetIndex%>-username'><%= tweet.username %></span>
          <% if (currentUser) {%>
          <div id='actions'>
              <% if (tweet.UserId===currentUser.dataValues.id) {%>
              <form action='/tweet/<%=tweet.id%>?_method=DELETE' method='post'>
                <input type='submit' value='Delete' id='tweet-<%=tweetIndex%>-delete' >
              </form>
              <a href='/tweet/<%=tweet.id%>/edit' id='tweet-<%=tweetIndex%>-edit'>Edit</a>
              <% }%>
              <a href='/tweet/<%=tweet.id%>/reply' id='tweet-<%=tweetIndex%>-reply'>Reply</a>
          </div>
          <%}%>
          
          <ul id='tweet-<%=tweetIndex%>-reply'>
          <% tweet.Replies.forEach( (reply, replyIndex) => { %>
              <li>
              <span id='tweet-<%= tweetIndex%>-reply-<%=replyIndex%>'><%=reply.text%> </span>
              <span id='tweet-<%= tweetIndex%>-reply-<%=replyIndex%>-timestamp'><%=reply.date()%></span>
              <span id='tweet-<%= tweetIndex%>-reply-<%=replyIndex%>-username'><%=reply.username%></span>
              <% if (currentUser) {%>
                <% if (reply.UserId===currentUser.dataValues.id) {%>
                <form action='tweet/<%=tweet.id%>/reply/<%=reply.id%>?_method=DELETE' method='post'>
                    <input type='submit' value='Delete' id='tweet-<%=tweetIndex%>-reply-<%=replyIndex%>-delete' >
                </form>
                <a href='/tweet/<%=tweet.id%>/reply/<%=reply.id%>/edit' id='tweet-<%=tweetIndex%>-reply-<%=replyIndex%>-edit'>Edit</a>
                <% } %>
              <% } %>
            </li>
          <% }) %>
          </ul>
          
        </div>
        <% }) %>
  </div>
  </body>
</html>
