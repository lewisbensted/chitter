{
	"name": "server",
	"version": "1.0.0",
	"description": "Chitter app backend built with Express and Prisma.",
	"main": "app.ts",
	"type": "module",
	"scripts": {
		
		"start": "set NODE_ENV=development&& nodemon src/app.ts",
		"migrate": "dotenv -e .env.development -- npx prisma migrate dev --name inititalise",
		"seed": "set NODE_ENV=development&& node --loader ts-node/esm prisma/seed.ts"
	},
	"license": "ISC",
	"devDependencies": {
		"@faker-js/faker": "^8.4.1",
		"@prisma/client": "^5.10.2",
		"@types/cookie-parser": "^1.4.7",
		"@types/express": "^4.17.21",
		"@types/express-session": "^1.18.0",
		"@types/node": "^20.11.25",
		"@typescript-eslint/eslint-plugin": "^7.1.1",
		"@typescript-eslint/parser": "^7.1.1",
		"eslint": "^8.57.0",
		"eslint-plugin-only-warn": "^1.1.0",
		"nodemon": "^3.1.0",
		"prisma": "^5.10.2",
		"ts-node": "^10.9.2",
		"typescript": "^5.4.2"
	},
	"dependencies": {
		"@types/bcrypt": "^5.0.2",
		"bcrypt": "^5.1.1",
		"cookie-parser": "^1.4.6",
		"dotenv": "^16.4.5",
		"dotenv-cli": "^7.4.0",
		"express": "^4.18.3",
		"express-session": "^1.18.0",
		"zod": "^3.22.4"
	}
}
